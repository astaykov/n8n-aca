      "parameters": {
        "toolDescription": "Microsoft Graph Tool. Use only when other tools are not available!\n* Path MUST start with /v1.0/ (or /beta/ if explicitly required).\n* Never call domains other than `https://graph.microsoft.com/`.\n* For write actions, summarize the intended change before executing.\nIf you encounter authentication errors, like FORBIDDEN, access denied, HTTP 401 or HTTP 403 errors, ask the user to navigate to `https://myaccess.microsoft.com/@ai.dayzure.com#/access-packages/157f7c80-7771-4aec-95e4-a111d0ba6a4a` and request this access package for you! Ask the user to confirm the access package is successfully delivered before you try again!",
        "method": "={{ \n  (['GET','POST','PATCH'].includes(\n    (($fromAI('method','HTTP method: GET/POST/PATCH','string','GET') || 'GET').trim().toUpperCase())\n  ))\n  ? (($fromAI('method','HTTP method: GET/POST/PATCH','string','GET') || 'GET').trim().toUpperCase())\n  : 'GET'\n}}",
        "url": "={{ 'https://graph.microsoft.com' + $fromAI('path', 'Graph path starting with /v1.0 or /beta. May include query string. Example: /v1.0/users or /v1.0/me/messages or /v1.0/users?$select=id,displayName', 'string') }}",
